# GembaTools — Environment Variables
# Copy this file to .env and fill in your values

# Deployer private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Fee recipients
FEE_RECIPIENT=YOUR_ADDRESS
SWAP_FEE_RECIPIENT=YOUR_ADDRESS
SWAP_PLATFORM_FEE=30

# RPC URLs
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia/your_key
ETHEREUM_RPC_URL=https://rpc.ankr.com/eth/your_key
BSC_RPC_URL=https://rpc.ankr.com/bsc/your_key
POLYGON_RPC_URL=https://rpc.ankr.com/polygon/your_key
BASE_RPC_URL=https://rpc.ankr.com/base/your_key

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_v2_key
BSCSCAN_API_KEY=your_bscscan_key
POLYGONSCAN_API_KEY=your_polygonscan_key
BASESCAN_API_KEY=your_basescan_key
